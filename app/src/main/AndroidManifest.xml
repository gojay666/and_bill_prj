<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="29"
        tools:ignore="ScopedStorage" />

    <application
        android:name=".BillApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.BillApp"
        tools:targetApi="31">

        <activity
            android:name=".ui.auth.LoginActivity"
            android:exported="true"
            android:theme="@style/Theme.BillApp">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".TestActivity"
            android:exported="true"
            android:theme="@style/Theme.BillApp" />

        <activity
            android:name=".ui.bill.MainActivity"
            android:exported="true"
            android:theme="@style/Theme.BillApp"
            android:configChanges="uiMode|orientation|screenSize" />

        <activity
            android:name=".ui.auth.RegisterActivity"
            android:exported="false"
            android:theme="@style/Theme.BillApp" />

        <activity
            android:name=".ui.auth.ForgotPasswordActivity"
            android:exported="false"
            android:theme="@style/Theme.BillApp" />

        <activity
            android:name=".ui.bill.AddBillActivity"
            android:exported="false"
            android:theme="@style/Theme.BillApp"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.bill.BillListActivity"
            android:exported="false"
            android:theme="@style/Theme.BillApp" />

        <activity
            android:name=".ui.bill.BillDetailActivity"
            android:exported="false"
            android:theme="@style/Theme.BillApp" />

        <activity
            android:name=".ui.account.AccountManageActivity"
            android:exported="false"
            android:theme="@style/Theme.BillApp" />

        <activity
            android:name=".ui.settings.CategoryManageActivity"
            android:exported="false"
            android:theme="@style/Theme.BillApp" />

        <activity
            android:name=".ui.budget.BudgetActivity"
            android:exported="false"
            android:theme="@style/Theme.BillApp" />

        <activity
            android:name=".ui.statistics.StatisticsActivity"
            android:exported="false"
            android:theme="@style/Theme.BillApp" />

        <activity
            android:name=".ui.settings.SettingsActivity"
            android:exported="false"
            android:theme="@style/Theme.BillApp" />
    </application>

</manifest>
